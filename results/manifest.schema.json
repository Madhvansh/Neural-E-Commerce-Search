{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Madhvansh/Neural-E-Commerce-Search/results/manifest.schema.json",
  "title": "Neural E-Commerce Search result bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_version",
    "git_commit",
    "dataset",
    "environment",
    "runs",
    "tables"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "project_version": {"type": "string", "minLength": 1},
    "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "revision", "locale", "split", "checksums_file"],
      "properties": {
        "source": {"type": "string", "format": "uri"},
        "revision": {"type": "string", "minLength": 1},
        "locale": {"enum": ["us", "es", "jp"]},
        "split": {"type": "string", "minLength": 1},
        "checksums_file": {"type": "string", "minLength": 1}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "dependencies_file", "hardware"],
      "properties": {
        "python": {"type": "string", "minLength": 1},
        "dependencies_file": {"type": "string", "minLength": 1},
        "hardware": {"type": "string", "minLength": 1}
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["system", "seed", "config", "predictions", "log"],
        "properties": {
          "system": {"type": "string", "minLength": 1},
          "seed": {"type": "integer"},
          "config": {"type": "string", "minLength": 1},
          "predictions": {"type": "string", "minLength": 1},
          "log": {"type": "string", "minLength": 1}
        }
      }
    },
    "tables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "generator", "command"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "generator": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
